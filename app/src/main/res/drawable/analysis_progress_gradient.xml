<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape><corners android:radius="4dp" /><color android:color="#2A2440" /></shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="4dp" />
                <gradient android:startColor="#8B5CF6" android:endColor="#06B6D4" android:angle="0" />
            </shape>
        </clip>
    </item>
</layer-list>