    <!-- American Tips -->
    <string name="accent_badge_american">🇺🇸 American English Tips</string>
    <string name="tip_subtitle_american">Coaching for American English delivery</string>
    <string name="tip_content_american">American English coaching focuses on directness, confidence,
        and natural conversational flow.\n\n• Replace filler words with a confident 1-second
        pause\n• Vary your pace: slow for emphasis (100 WPM), faster during narrative (170 WPM)\n•
        Use rising intonation for questions, falling for statements\n• Project from the diaphragm —
        avoid dropping volume at sentence ends\n• Practice rhotic \'R\' sounds clearly: \'career\',
        \'butter\', \'corner\'
    </string>

    <!-- British Tips -->
    <string name="accent_badge_british">🇬🇧 British English Tips</string>
    <string name="tip_subtitle_british">Coaching for British English delivery</string>
    <string name="tip_content_british">British English coaching emphasises precision, composure, and
        structured rhetoric.\n\n• Use deliberate 2-second pauses after key points — it signals
        authority\n• Avoid glottal stops in formal speech (\'butter\' → \'butter\')\n• Signpost your
        speech: \'Firstly… Moving on… In conclusion…\'\n• Use understatement strategically for
        impact\n• Non-rhotic pronunciation: \'car\' rhymes with \'spa\', not \'star\'
    </string>

    <!-- Indian Tips -->
    <string name="accent_badge_indian">🇮🇳 Indian English Tips</string>
    <string name="tip_subtitle_indian">Coaching for Indian English delivery</string>
    <string name="tip_content_indian">Indian English coaching focuses on intonation variety, filler
        reduction, and pace control.\n\n• Reduce filler words (\'basically\', \'only\', \'na\') with
        a brief pause\n• Vary your pitch more — Indian English can sound monotone to some
        audiences\n• Slow down at the end of sentences — avoid trailing off\n• Stress the correct
        syllable: \'pho-TO-graph\' not \'PHO-to-graph\'\n• Practice word stress: \'I didn\'t SAY he
        stole it\' vs \'I didn\'t say HE stole it\'
    </string>
