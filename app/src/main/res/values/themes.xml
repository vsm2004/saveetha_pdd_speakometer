<resources>

    <!-- Main App Theme -->
    <style name="Theme.Speakometer" parent="Theme.Material3.DayNight.NoActionBar" />

    <!-- Splash Theme -->
    <style name="Theme.Speakometer.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@drawable/speakometer_logo</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/talking_symbol</item>
        <item name="windowSplashScreenAnimationDuration">1500</item>
        <item name="postSplashScreenTheme">@style/Theme.Speakometer</item>
    </style>
    <!-- Add this inside your resources tag -->
    <style name="CustomSwitchTheme">
        <item name="colorControlActivated">#06B6D4</item>
        <item name="colorSwitchThumbNormal">#FFFFFF</item>
        <item name="android:colorForeground">#9CA3AF</item>
    </style>

</resources>
