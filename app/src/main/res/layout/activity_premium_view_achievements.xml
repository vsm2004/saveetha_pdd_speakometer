<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0618"
    tools:context=".PremiumViewAchievementsActivity">

    <!-- Subtle Glow behind icon at top -->
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/bg_premium_star_circle"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-20dp" />

    <!-- Circle Icon Gradient background -->
    <FrameLayout
        android:id="@+id/flBadgeIcon"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/bg_achievement_circle_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_ribbon_white_outline"
            android:contentDescription="@string/achievement_badge_icon" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvAchievementTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="24dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="@string/achievement_title"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/flBadgeIcon" />

    <!-- Pill for Badge Name -->
    <TextView
        android:id="@+id/tvBadgeNamePill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_badge_pill_gradient"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:text="@string/achievement_badge_name"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAchievementTitle" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvAchievementDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:text="@string/achievement_description"
        android:textColor="#B3B3B3"
        android:textSize="16sp"
        android:lineSpacingExtra="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBadgeNamePill" />

    <!-- White Stats Card -->
    <LinearLayout
        android:id="@+id/llStatsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_white_rounded_card"
        android:orientation="horizontal"
        android:paddingVertical="24dp"
        android:weightSum="3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAchievementDesc">

        <!-- Stat 1 -->
        <TextView
            android:id="@+id/tv_ach_stat_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/achievement_stat_1_val"
            android:textColor="#06B6D4"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Stat 2 -->
        <TextView
            android:id="@+id/tv_ach_stat_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/achievement_stat_2_val"
            android:textColor="#8A4DFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Stat 3 -->
        <TextView
            android:id="@+id/tv_ach_stat_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/achievement_stat_3_val"
            android:textColor="#FA67BC"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom Button Text -->
    <TextView
        android:id="@+id/btnAwesome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="@string/achievement_btn_awesome"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
