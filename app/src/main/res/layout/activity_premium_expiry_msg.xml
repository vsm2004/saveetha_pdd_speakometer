<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0618"
    tools:context=".PremiumExpiryActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp">

            <!-- Top Alert Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clAlertCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_expiry_alert_card"
                android:padding="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:id="@+id/flAlertIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_glow_pink" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_alert_triangle_pink"
                        android:contentDescription="@null" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvAlertMsg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/expiry_alert_msg"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"
                    app:layout_constraintStart_toEndOf="@id/flAlertIcon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="16dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    app:layout_constraintStart_toEndOf="@id/flAlertIcon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAlertMsg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/expiry_date_label"
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/expiry_date_val"
                        android:textColor="#FA67BC"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tvLoseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="@string/expiry_lose_title"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clAlertCard" />

            <LinearLayout
                android:id="@+id/llFeaturesList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/tvLoseTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Feature 1 Optimized -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_expiry_list_item"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp"
                    android:gravity="center_vertical"
                    android:text="@string/expiry_feature_1"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:drawablePadding="16dp"
                    app:drawableStartCompat="@drawable/ic_sparkle_cyan" />

                <!-- Feature 2 Optimized -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_expiry_list_item"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp"
                    android:gravity="center_vertical"
                    android:text="@string/expiry_feature_2"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:drawablePadding="16dp"
                    app:drawableStartCompat="@drawable/ic_sparkle_cyan" />

                <!-- Feature 3 Optimized -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_expiry_list_item"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp"
                    android:gravity="center_vertical"
                    android:text="@string/expiry_feature_3"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:drawablePadding="16dp"
                    app:drawableStartCompat="@drawable/ic_sparkle_cyan" />

                <!-- Feature 4 Optimized -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_expiry_list_item"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp"
                    android:gravity="center_vertical"
                    android:text="@string/expiry_feature_4"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:drawablePadding="16dp"
                    app:drawableStartCompat="@drawable/ic_sparkle_cyan" />

                <!-- Feature 5 Optimized -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_expiry_list_item"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="18dp"
                    android:gravity="center_vertical"
                    android:text="@string/expiry_feature_5"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:drawablePadding="16dp"
                    app:drawableStartCompat="@drawable/ic_sparkle_cyan" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_button_gradient_indigo"
                android:alpha="0.3"
                android:scaleX="1.05"
                android:scaleY="1.1"
                app:layout_constraintTop_toBottomOf="@id/llFeaturesList"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRenew"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_button_gradient_indigo"
                android:text="@string/expiry_btn_renew"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/llFeaturesList"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/btnMaybeLater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                android:text="@string/expiry_btn_later"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/btnRenew"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Optimized Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#100C1C"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_home"
            android:textColor="#8A8A8E"
            android:textSize="11sp"
            android:drawablePadding="4dp"
            app:drawableTint="#8A8A8E"
            app:drawableTopCompat="@drawable/home_normal" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_history"
            android:textColor="#8A8A8E"
            android:textSize="11sp"
            android:drawablePadding="4dp"
            app:drawableTint="#8A8A8E"
            app:drawableTopCompat="@drawable/history" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_practice"
            android:textColor="#8A8A8E"
            android:textSize="11sp"
            android:drawablePadding="4dp"
            app:drawableTint="#8A8A8E"
            app:drawableTopCompat="@drawable/practice" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_profile"
            android:textColor="#8A8A8E"
            android:textSize="11sp"
            android:drawablePadding="4dp"
            app:drawableTint="#8A8A8E"
            app:drawableTopCompat="@drawable/profile" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>