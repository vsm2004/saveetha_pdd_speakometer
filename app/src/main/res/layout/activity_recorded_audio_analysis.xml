<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0B1F"
    android:padding="24dp">

    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="100dp"
        android:indeterminateTint="#06B6D4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_analyzing_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/analyzing_speech"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loading_spinner" />

    <TextView
        android:id="@+id/tv_analyzing_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/take_a_moment"
        android:textColor="#B3FFFFFF"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_analyzing_title" />

    <ProgressBar
        android:id="@+id/analysis_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="40dp"
        android:progress="40"
        android:progressDrawable="@drawable/analysis_progress_gradient"
        app:layout_constraintTop_toBottomOf="@id/tv_analyzing_subtitle" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/analysis_progress_bar">

        <TextView
            android:id="@+id/status_filler"
            style="@style/AnalysisStatusText"
            android:text="@string/detecting_filler"
            app:drawableStartCompat="@drawable/ic_status_dot" />

        <TextView
            android:id="@+id/status_tone"
            style="@style/AnalysisStatusText"
            android:layout_marginTop="16dp"
            android:text="@string/analyzing_tone"
            app:drawableStartCompat="@drawable/ic_status_dot" />

        <TextView
            android:id="@+id/status_score"
            style="@style/AnalysisStatusText"
            android:layout_marginTop="16dp"
            android:text="@string/calculating_score"
            app:drawableStartCompat="@drawable/ic_status_dot" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>