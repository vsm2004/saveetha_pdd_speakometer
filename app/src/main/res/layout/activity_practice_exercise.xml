<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0B1F"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btn_back_to_tips"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="@string/desc_back_button"
        android:src="@drawable/upper_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tv_exercise_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/reduce_filler_words"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back_to_tips" />

    <TextView
        android:id="@+id/tv_exercise_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#B3FFFFFF"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_exercise_title" />

    <!-- === PROMPT VIEW (shown when NOT completed) === -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="@drawable/card_outline_bg"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_exercise_meta">

        <TextView
            android:id="@+id/tv_prompt_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/your_prompt"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_prompt_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/exercise_prompt"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_prompt_header" />

        <ImageView
            android:id="@+id/iv_tip_bulb"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="24dp"
            android:contentDescription="@string/desc_tip_icon"
            android:src="@drawable/glow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_prompt_content"
            app:tint="#FACC15" />

        <TextView
            android:id="@+id/tv_tip_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/label_tip"
            android:textColor="#06B6D4"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/iv_tip_bulb"
            app:layout_constraintStart_toEndOf="@id/iv_tip_bulb"
            app:layout_constraintTop_toTopOf="@id/iv_tip_bulb" />

        <TextView
            android:id="@+id/tv_tip_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/exercise_implementation_tip"
            android:textColor="#06B6D4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_tip_label"
            app:layout_constraintTop_toTopOf="@id/tv_tip_label" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/iv_visualizer"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="90dp"
        android:contentDescription="@string/desc_visualizer"
        android:src="@drawable/wave_graphics"
        app:layout_constraintTop_toBottomOf="@id/card_prompt" />

    <!-- Start Recording button (shown when NOT completed) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_start_recording"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/create_account_bg"
        android:drawableStart="@drawable/ic_mic"
        android:drawablePadding="-40dp"
        android:paddingStart="80dp"
        android:paddingEnd="80dp"
        android:text="@string/start_recording"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- === COMPLETED RESULTS VIEW (hidden by default, shown when completed) === -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_results"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="@drawable/card_outline_bg"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_exercise_meta">

        <!-- Completed badge -->
        <TextView
            android:id="@+id/tv_completed_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ Exercise Completed"
            android:textColor="#4ADE80"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_practice_card_outline"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Last score -->
        <TextView
            android:id="@+id/tv_last_score_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Your Last Score"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_completed_badge" />

        <TextView
            android:id="@+id/tv_last_score_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="—"
            android:textColor="#06B6D4"
            android:textSize="48sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_last_score_label" />

        <TextView
            android:id="@+id/tv_last_score_denom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/ 100"
            android:textColor="#9CA3AF"
            android:textSize="18sp"
            android:layout_marginStart="4dp"
            app:layout_constraintStart_toEndOf="@id/tv_last_score_value"
            app:layout_constraintBottom_toBottomOf="@id/tv_last_score_value" />

        <!-- Filler / Hesitation / Pace mini stats -->
        <TextView
            android:id="@+id/tv_result_detail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_last_score_value" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Do it Again button (shown when completed, replaces start button) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_do_again"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/create_account_bg"
        android:drawableStart="@drawable/ic_mic"
        android:drawablePadding="-40dp"
        android:paddingStart="60dp"
        android:paddingEnd="60dp"
        android:text="🔄  Do it Again"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- View Full Results button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_view_full_results"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_practice_card_outline"
        android:text="View Full Analysis"
        android:textAllCaps="false"
        android:textColor="#06B6D4"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btn_do_again" />

</androidx.constraintlayout.widget.ConstraintLayout>
